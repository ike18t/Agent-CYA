{
  "name": "agent-cya",
  "version": "0.3.0-alpha.1",
  "description": "CLI that reviews AI coding harness tool calls (Claude Code, OpenCode) before execution via hooks",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agent-cya": "bin/agent-cya"
  },
  "files": [
    "bin/",
    "dist/",
    "config.schema.json"
  ],
  "exports": {
    "./opencode": "./dist/harnesses/opencode-plugin.js",
    "./package.json": "./package.json"
  },
  "keywords": [
    "opencode-plugin",
    "claude-code",
    "permission"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "lint": "tsc --noEmit && eslint . && prettier . --check && knip",
    "lint:fix": "eslint . --fix && prettier . --write ."
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.4",
    "@types/node": "^24.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-functional": "^10.0.0",
    "knip": "^6.4.1",
    "prettier": "^3.8.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.1.2"
  },
  "author": "Isaac Datlof",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ike18t/Agent-CYA.git"
  },
  "bugs": {
    "url": "https://github.com/ike18t/Agent-CYA/issues"
  },
  "homepage": "https://github.com/ike18t/Agent-CYA#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  }
}
